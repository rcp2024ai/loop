{
  "manifest_version": 3,
  "name": "LOOP by BetterWayAI — Close Every Task",
  "short_name": "LOOP",
  "version": "1.0.0",
  "description": "AI-powered daily workflow that eliminates procrastination: dump, triage, commit to one, execute, close the loop.",
  "permissions": ["sidePanel", "storage", "idle", "alarms", "tabs"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": { "default_title": "Open LOOP" },
  "side_panel": { "default_path": "sidebar.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "options_page": "settings.html",
  "icons": { "16": "icons/16.png", "48": "icons/48.png", "128": "icons/128.png" }
}
